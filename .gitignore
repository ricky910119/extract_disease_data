# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Python build / package files
build/
dist/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Runtime logs
logs/*.log
logs/*.txt
!logs/.gitkeep

# Runtime state
state/*.json
!state/state.example.json
!state/.gitkeep

# Local / NAS raw cache
*.csv
*.parquet
*.duckdb
*.db
*.sqlite
*.sqlite3

# Project generated archives
*.zip
*.tar
*.tar.gz

# Environment / secrets
.env
.env.*
*.key
*.pem
*.crt

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Temporary files
*.tmp
*.temp
*.bak